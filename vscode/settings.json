{
  "debug.console.historySuggestions": false,
  "editor.cursorBlinking": "smooth",
  "editor.cursorStyle": "block",
  "editor.fontFamily": "Cascadia Code, Hack",
  "editor.fontLigatures": true,
  "editor.fontSize": 17,
  "editor.minimap.renderCharacters": false,
  "editor.quickSuggestions": {
    "other": "on",
    "comments": "on",
    "strings": "on"
  },
  "explorer.compactFolders": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "extensions.ignoreRecommendations": true,
  "files.autoGuessEncoding": true,
  "files.autoSave": "afterDelay",
  "files.insertFinalNewline": true,
  "git.autofetch": true,
  "git.autorefresh": true,
  "git.confirmSync": false,
  "git.openAfterClone": "whenNoFolderOpen",
  "git.openRepositoryInParentFolders": "never",
  "github.gitProtocol": "ssh",
  "go.toolsManagement.autoUpdate": true,
  "json.schemaDownload.enable": false,
  "python.analysis.autoImportCompletions": true,
  "python.analysis.typeCheckingMode": "basic",
  "redhat.telemetry.enabled": false,
  "security.workspace.trust.enabled": false,
  "security.workspace.trust.startupPrompt": "never",
  "terminal.integrated.enableMultiLinePasteWarning": false,
  "terminal.integrated.enablePersistentSessions": false,
  "terminal.integrated.env.windows": {},
  "terminal.integrated.fontSize": 16,
  "terminal.integrated.shellIntegration.history": 0,
  "window.restoreWindows": "none",
  "workbench.colorTheme": "Catppuccin Mocha",
  "workbench.editor.enablePreview": false,
  "workbench.iconTheme": "material-icon-theme",
  "workbench.startupEditor": "none",
  "remote.SSH.configFile": "~/.ssh/config",
  "remote.autoForwardPorts": false,
  "[lua]": {
    "editor.defaultFormatter": "sumneko.lua"
  },
  "github.copilot.enable": {
    "*": false,
  },
  "github.copilot.nextEditSuggestions.enabled": false,
  "docker.extension.enableComposeLanguageServer": false,
  "update.showReleaseNotes": false,
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter"
  },
  "python.defaultInterpreterPath": "c:\\Users\\zjuche\\.local\\bin\\python3.14.exe",
  "editor.stickyScroll.enabled": false,
  "diffEditor.renderSideBySide": false,
  "diffEditor.ignoreTrimWhitespace": true,
  "docker.extension.dockerEngineAvailabilityPrompt": false,
  "[typescript]": {
    "editor.defaultFormatter": "denoland.vscode-deno"
  },
  "remote.SSH.remotePlatform": {
    "192.168.1.73": "linux",
    "192.168.1.202": "linux",
    "192.168.1.203": "linux"
  },
  "workbench.sideBar.location": "right",
  "chat.viewSessions.orientation": "stacked",
  "diffEditor.hideUnchangedRegions.enabled": true,
  "C_Cpp.intelliSenseEngine": "disabled",
  "[cpp]": {
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
  },
  "makefile.configureOnOpen": true,
  "editor.minimap.enabled": false,
  "terminal.integrated.initialHint": false,
}
